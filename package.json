{
  "name": "design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "assets:screenshot-versions": "node scripts/generate-screenshot-asset-versions.mjs",
    "dev": "next dev",
    "build": "pnpm assets:screenshot-versions && next build",
    "build:static": "pnpm assets:screenshot-versions && NEXT_OUTPUT=export next build",
    "build:cloudflare": "pnpm assets:screenshot-versions && NEXT_PUBLIC_ASSET_BASE_URL=${NEXT_PUBLIC_ASSET_BASE_URL:-https://arena-assets.xflux.cn} NEXT_OUTPUT=export next build",
    "db:migrate:remote": "pnpm dlx wrangler@latest d1 migrations apply design-skill-arena-votes --remote",
    "deploy:cloudflare": "pnpm build:cloudflare && pnpm dlx wrangler@latest pages deploy out --project-name design-skill-arena --branch main",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview:static": "serve out"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "serve": "^14.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
